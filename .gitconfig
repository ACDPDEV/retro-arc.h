# .gitconfig shared - colócalo en la raíz del repo
[alias]
    prechange = !git checkout main && git pull --ff-only
    fresh = !git fetch origin main && git rebase origin/main
    cleanup = !git checkout main && git pull --ff-only && git fetch -p && git branch -d $(git branch --merged | grep -v "^*")
    fixup = !git commit --fixup
    pushf = push --force-with-lease
    lg = log --oneline --graph --decorate -20