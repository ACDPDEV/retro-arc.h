# Project: TicTacToeFutbol
# Linux Makefile — all game logic is header-only (.h files)
CPP      = g++
OBJ      = main.o
LINKOBJ  = main.o
CXXINCS  = -I../../
CXXFLAGS = -std=c++17 $(CXXINCS) -Wall
BIN      = TicTacToeFutbol
LIBS     = -lpthread

$(BIN): $(OBJ)
	$(CPP) $(LINKOBJ) -o $(BIN) $(LIBS)

main.o: main.cpp
	$(CPP) -c main.cpp -o main.o $(CXXFLAGS)

clean:
	rm -f $(OBJ) $(BIN)
