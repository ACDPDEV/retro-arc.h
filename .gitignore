# Binaries and compiled objects
*.o
*.gch
*.exe

# Compiled executables without extension (Linux ELF)
# These are typically generated by Makefile
main
pokemon_game
test_*

# Ignore directories
*/

# Don't ignore files with extensions (dotfiles, source files, etc.)
!ICENSE

# Don't ignore Juegos source files
!Juegos/
!Juegos/**/
!Juegos/**/*.h
!Juegos/**/*.cpp

# Don't ignore Common source files
!Common/
!Common/**/
!Common/**/*.h
!Common/**/*.cpp

# Don't ignore Tests source files
!Tests/
!Tests/**/
!Tests/**/*.cpp
!Tests/**/*.h

# Don't ignore MainMenu source files
!MainMenu/
!MainMenu/**/
!MainMenu/**/*.h
!MainMenu/**/*.cpp

# Don't ignore GitHub Actions workflows
!.github/
!.github/**/
!.github/**/*.yml

# Don't ignore .clang-format
!.clang-format

# Ignore specific directories
openspec/
sdd/
.vscode/
.atl/
.clangd/
bin/
build/

# Compiled test executables
Tests/*Test
Tests/TestingGraphics/testingBoxes

# Specific game builds
Juegos/Tictactoe/TicTacToeFutbol

# Ignore specific files
.clangd
AGENTS.md
CommonDOCS.md
GUIA_GIT_WORKFLOW.md
requirements.pdf
compile_commands.json
Informe_RetroArc_2026.docx
